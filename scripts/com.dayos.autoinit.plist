<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dayos.autoinit</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/day</string>
        <string>init</string>
    </array>

    <!-- Run daily at 6:00 AM (before earliest wake time across all profiles) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/dayos-autoinit.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/dayos-autoinit.log</string>
</dict>
</plist>
